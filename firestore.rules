rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /series/{id} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'itzlokaya@gmail.com';
    }
    match /episodes/{id} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'itzlokaya@gmail.com';
    }
  }
}
